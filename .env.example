# E-Commerce Adapter Configuration
# Options: mock, shopify, custom
# mock: 使用本地模拟数据（开发测试用）
# shopify: 使用真实 Shopify API（正式环境用）
VITE_ECOMMERCE_ADAPTER=mock

# Shopify Storefront API
VITE_SHOPIFY_STOREFRONT_API_TOKEN=your_storefront_api_token
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_API_VERSION=2024-07

# Shopify Admin API (optional, for server-side only)
SHOPIFY_ADMIN_API_TOKEN=your_admin_api_token

# App Configuration
VITE_APP_NAME=Ecommerce Store
VITE_DEFAULT_LOCALE=en
VITE_SUPPORTED_LOCALES=en,zh
VITE_APP_VERSION=1.0.0

# Analytics (optional)
VITE_GA_MEASUREMENT_ID=your_ga_id

# Sentry (optional)
VITE_SENTRY_DSN=your_sentry_dsn
